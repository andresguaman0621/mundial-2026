# Turso (libSQL) — credenciales de tu base de datos.
# Estas variables viven SOLO en el servidor (Vercel Serverless Functions),
# nunca se exponen al navegador.
TURSO_DATABASE_URL=libsql://tu-base.turso.io
TURSO_AUTH_TOKEN=tu-auth-token

# Password del panel de administración (se valida del lado del servidor).
ADMIN_PASSWORD=mundial2026
